{
    "manifest_version": 3,
    "name": "ize-gender",
    "version": "1.0",
  
    "description": "make everything gendered smh",
  
    "icons": {
      "48": "icons/border-48.png"
    },
  
    "browser_specific_settings": {
      "gecko": {
        "id": "borderify@mozilla.org",
        "data_collection_permissions": {
          "required": ["none"]
        }
      }
    },
  
    "content_scripts": [
      {
        "matches": ["*://*.mozilla.org/*"],
        "js": ["borderify.js"]
      }
    ]
  }